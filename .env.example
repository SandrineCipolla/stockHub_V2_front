# ======================================================
# StockHub V2 Front — Variables d'environnement
# Copiez ce fichier en .env et renseignez vos valeurs.
# Ne committez jamais le fichier .env.
# ======================================================

# --- Azure AD B2C ---
VITE_CLIENT_ID=your-azure-b2c-client-id
VITE_TENANT_NAME=your-b2c-tenant-name
VITE_AUTHORITY_DOMAIN=your-tenant.b2clogin.com

# Politiques B2C
VITE_SIGN_UP_SIGN_IN_POLICY=B2C_1_signupsignin
VITE_FORGOT_PASSWORD_POLICY=B2C_1_passwordreset
VITE_EDIT_PROFILE_POLICY=B2C_1_profileediting

# --- API Backend ---
VITE_API_SERVER_URL=https://your-backend-url.azurewebsites.net
VITE_API_V1=/api/v1
VITE_API_V2=/api/v2

# --- Scopes OAuth2 ---
VITE_SCOPE_READ=https://your-tenant.onmicrosoft.com/your-client-id/access_as_user
VITE_SCOPE_WRITE=https://your-tenant.onmicrosoft.com/your-client-id/access_as_user

# --- Vite Build ---
VITE_BASE_PATH=/
